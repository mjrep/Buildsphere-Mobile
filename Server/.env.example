NODE_ENV=production
PORT=5000

# PostgreSQL connection used by the Express API.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Supabase backend credentials. Keep the service-role key on the backend only.
SUPABASE_URL=https://gadhovevmzmzesiqgubb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Optional comma-separated browser origins for deployed web clients.
# Mobile apps usually send no Origin header and are allowed by the API.
CORS_ORIGINS=https://your-buildsphere-web.example.com

# Supabase Auth password reset / OTP signing.
JWT_SECRET=replace-with-a-long-random-secret

# Email OTP delivery.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=your-gmail-address@gmail.com

# Gemini glass analysis.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
AI_ANALYSIS_MODE=gemini_only

# Never enable OTP logging in production.
LOG_RESET_OTP=false
TZ=Asia/Singapore
