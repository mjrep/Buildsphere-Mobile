# Public mobile configuration only.
# Do not put Gemini or backend service-role keys in this file.
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3001
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
# Standalone/dev build default. Expo Go can require its generated exp:// redirect URL instead.
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=buildsphere://reset-password
