# BuildSphere CV Service — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environment
venv/
.venv/
env/

# YOLO model weights (large binary files)
*.pt
models/*.onnx
!models/.gitkeep

# Training outputs
runs/
datasets/

# Environment variables (contains secrets)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
htmlcov/
.coverage
